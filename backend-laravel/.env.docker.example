APP_NAME=Nexora
APP_ENV=production
APP_KEY=base64:PLACEHOLDER_LARAVEL_APP_KEY
APP_DEBUG=false
APP_URL=https://nexoraappbr.com

LOG_CHANNEL=stderr
LOG_LEVEL=error

DB_CONNECTION=pgsql
DATABASE_URL=PLACEHOLDER_NEON_DATABASE_URL
DB_SSLMODE=require
DB_DISABLE_PREPARES=true
DB_EMULATE_PREPARES=false

NEXORA_ENV=prod
NEXORA_CORS_ORIGINS=https://nexoraappbr.com,https://www.nexoraappbr.com
NEXORA_ADMIN_TOKEN=PLACEHOLDER_32_PLUS_RANDOM_CHARS
NEXORA_DATA_KEY_B64=PLACEHOLDER_BASE64_32_BYTE_KEY
NEXORA_CPF_PEPPER=PLACEHOLDER_LONG_RANDOM_PEPPER
NEXORA_ADMIN_PIX_KEY=PLACEHOLDER_ADMIN_FEE_PIX_KEY
NEXORA_SUPPORT_PIX_KEY=PLACEHOLDER_PLATFORM_SUPPORT_PIX_KEY_EVP_OR_CNPJ
NEXORA_PIX_MERCHANT_NAME=NEXORA
NEXORA_PIX_MERCHANT_CITY=SAO PAULO
NEXORA_SUPER_ADMIN_EMAIL=PLACEHOLDER
NEXORA_SUPER_ADMIN_CPF=PLACEHOLDER
NEXORA_SUPER_ADMIN_PASSWORD=PLACEHOLDER
NEXORA_CONTRIBUTION_EXPIRATION_MINUTES=30

SESSION_DRIVER=array
CACHE_STORE=array
QUEUE_CONNECTION=sync

MAIL_MAILER=smtp
MAIL_HOST=PLACEHOLDER_SMTP_HOST
MAIL_PORT=587
MAIL_USERNAME=nexora@nexoraappbr.com
MAIL_PASSWORD=PLACEHOLDER_SMTP_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=nexora@nexoraappbr.com
MAIL_FROM_NAME="Nexora"

OCR_PROVIDER=ocrspace
OCR_SPACE_API_KEY=PLACEHOLDER_OCR_SPACE_API_KEY
OCR_SPACE_LANGUAGE=por
OCR_SPACE_ENGINE=2
TESSERACT_CMD=tesseract
TESSERACT_LANGUAGE=por
TESSERACT_PSM=3
